---
// The look and feel of this component is mirrored by the `Schema` component in
// recivi, which documents a generated JSON schema. Keep the two visually in sync.
// https://github.com/recivi/recivi/blob/main/docs/src/components/Schema.astro
import { Badge } from "@astrojs/starlight/components";

let { title, fqTitle, required, type, subfieldsType } = Astro.props;
---

<div class="doc-block">
	<div class="header">
		<div class="name">
			<slot name="heading">
				<span id={fqTitle || title}>{title}</span>
			</slot>
		</div>
		{type && <Badge text={type} />}
		{required && <Badge text="required" variant="caution" />}
	</div>

	<slot />

	{
		Astro.slots.has("subfields") && (
			<details>
				<summary>
					Properties of <code>{subfieldsType || type}</code>
				</summary>
				<slot name="subfields" />
			</details>
		)
	}

	{
		Astro.slots.has("examples") && (
			<details>
				<summary>
					Examples of <code>{title}</code>
				</summary>
				<slot name="examples" />
			</details>
		)
	}
</div>

<style>
	div.header {
		display: flex;
		flex-wrap: wrap;
		align-items: baseline;
		gap: 0.5rem;
	}

	/* Field names are literal config keys, so render them in the same mono face
	used for inline code. The heading slot keeps Starlight's anchor link and TOC
	entry; the fallback `span` is used for nested fields to avoid flooding it. */
	div.name {
		font-weight: 600;
		color: var(--sl-color-white);
	}

	div.name,
	div.name :is(h1, h2, h3, h4, h5, h6) {
		font-family: var(--__sl-font-mono);
	}
</style>
